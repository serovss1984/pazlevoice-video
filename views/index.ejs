<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pazl Voice — Многоголосный закадровый перевод</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <main class="container main-layout">
        
        <section class="content-area">
            <h2 class="section-title">Последние поступления</h2>
            
            <div class="grid">
                <% items.forEach(item => { %>
                <a href="/watch/<%= item.slug %>" class="card">
                    <div class="poster">
                        <img src="<%= item.poster_url || 'https://via.placeholder.com/300x450/111/fff?text=' + encodeURIComponent(item.title) %>" alt="<%= item.title %>" loading="lazy">
                        
                        <div class="badge-tag category-badge"><%= item.category_name %></div>
                        
                        <% if(item.imdb_rating){ %>
                            <div class="rating-badge imdb">IMDb <%= item.imdb_rating %></div>
                        <% } %>
                    </div>
                    <div class="info">
                        <h3><%= item.title %></h3>
                        <div class="meta">
                            <span class="year"><%= item.year %></span>
                        </div>
                    </div>
                </a>
                <% }) %>
            </div>



            <% if (totalPages > 1) { %>
                <div class="pagination">
                    <div class="pag-pages">
                    <% if (currentPage > 1) { %>
                        <a href="/?page=<%= currentPage - 1 %>" class="pag-btn">&larr; Назад</a>
                    <% } %>

                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <a href="/?page=<%= i %>" class="pag-link <%= currentPage === i ? 'active' : '' %>">
                                <%= i %>
                            </a>
                        <% } %>

                    <% if (currentPage < totalPages) { %>
                        <a href="/?page=<%= currentPage + 1 %>" class="pag-btn">Вперед &rarr;</a>
                    <% } %>
                    </div>
                </div>
            <% } %>


        </section>

        <aside class="sidebar-area">
            <div class="sidebar-block">
                <h3>Обновления сериалов</h3>
                
                <% if (sidebarSerials && sidebarSerials.length > 0) { %>
                    <ul class="sidebar-list">
                        <% sidebarSerials.forEach(serial => { %>
                            <li>
                                <a href="/watch/<%= serial.slug %>" class="sidebar-item-link">
                                    <span class="serial-title"><%= serial.title %> (<%= serial.updated_to %>)</span>
                                </a>
                            </li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p style="color: #666; font-size: 0.9rem;">Нет обновленных сериалов</p>
                <% } %>
            </div>
        </aside>

    </main>

    <%- include('partials/footer') %>

    <script src="/js/app.js"></script>
</body>
</html>
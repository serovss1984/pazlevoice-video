<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pazl Voice — Медиа библиотека</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <div class="logo">
            <img src="/images/logo.png" alt="Pazl Voice" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline'">
            <span class="logo-text" style="display:none">Pazl Voice</span>
        </div>
        <nav><a href="/admin">Админ-панель</a></nav>
    </header>

    <main class="container">
        <% Object.values(grouped).forEach(cat => { %>
        <section class="category-section" data-category="<%= cat.slug %>">
            <div class="category-header" onclick="toggleCategory('<%= cat.slug %>')">
                <h2><%= cat.name %></h2>
                <span class="toggle-icon">▼</span>
            </div>
            <div class="category-content" id="cat-<%= cat.slug %>">
                <div class="grid">
                    <% cat.items.forEach(item => { %>
                    <a href="/watch/<%= item.slug %>" class="card">
                        <div class="poster">
                            <img src="<%= item.poster_url || 'https://via.placeholder.com/300x450/111/fff?text=' + encodeURIComponent(item.title) %>" alt="<%= item.title %>" loading="lazy">
                            <% if(item.imdb_rating){ %><div class="rating-badge imdb">IMDb <%= item.imdb_rating %></div><% } %>
                        </div>
                        <div class="info">
                            <h3><%= item.title %></h3>
                            <div class="meta">
                                <span class="year"><%= item.year %></span>
                                <div class="ratings">
                                    <% if(item.kinopoisk_rating){ %><span class="kp">KP <%= item.kinopoisk_rating %></span><% } %>
                                    <% if(item.rotten_tomatoes_rating){ %><span class="rt">RT <%= item.rotten_tomatoes_rating %>%</span><% } %>
                                </div>
                            </div>
                        </div>
                    </a>
                    <% }) %>
                </div>
            </div>
        </section>
        <% }) %>
    </main>

    <script src="/js/app.js"></script>
</body>
</html>
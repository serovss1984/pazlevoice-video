<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= item.title %> — Pazl Voice</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/playerjs.js"></script>
</head>
<body>
    <header>
        <a href="/" class="back-btn">← Назад</a>
        <div class="logo-small">Pazl Voice</div>
    </header>

    <main class="watch-page">
        <div class="content-info">
            <h1><%= item.title %></h1>
            <% if(item.original_title){ %><h2 class="original"><%= item.original_title %></h2><% } %>

                <% if(item.rated || item.released || item.runtime || item.genre || item.country){ %>
            <div class="meta-details">
                <% if(item.rated){ %><span class="badge"><%= item.rated %></span><% } %>
                <% if(item.released){ %><span><%= item.released %></span><% } %>
                <% if(item.runtime){ %><span><%= item.runtime %></span><% } %>
                <% if(item.genre){ %><span class="genre"><%= item.genre %></span><% } %>
                <% if(item.country){ %><span><%= item.country %></span><% } %>
                <% if(item.imdb_rating){ %><a href="https://www.imdb.com/title/<%= item.imdb_id %>/" target="_blank" class="rating-item imdb">IMDb: <%= item.imdb_rating %></a><% } %>
            </div>
            <% } %>

            <% if(item.director || item.writer){ %>
            <div class="meta-details">
                <div class="crew">
                    <% if(item.director){ %><p><strong>Режиссёр:</strong> <%= item.director %></p><% } %>
                    <% if(item.writer){ %><p><strong>Сценарист:</strong> <%= item.writer %></p><% } %>
                </div>
            </div>
            <% } %>

            <% if(item.actors){ %>
            <div class="meta-details">
                <div class="actors">
                    <strong>В ролях:</strong> <%= item.actors %>
                </div>
            </div>
            <% } %>

            <div class="meta-details">
                <%= item.description %>
            </div>

        </div>

        <div class="player-container">
            <div id="player"></div>
        </div>

    </main>

    <script>
        <% if (item.is_playlist) { %>
        var player = new Playerjs({
            id: "player",
            file: <%- JSON.stringify(item.playlist) %>,
            poster: "<%= item.poster_url || '' %>"
        });
        <% } else { %>
        var player = new Playerjs({
            id: "player",
            file: "<%= item.player_url || '' %>",
            poster: "<%= item.poster_url || '' %>"
        });
        <% } %>
    </script>
</body>
</html>
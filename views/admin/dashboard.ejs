<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Админ-панель</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">
    <header class="admin-header">
        <h1>Админ-панель</h1>
        <a href="/admin/add" class="btn btn-primary">+ Добавить контент</a>
        <a href="/" class="btn">На сайт</a>
        <a href="/admin/logout" class="btn btn-danger">Выход</a>
    </header>

    <main class="admin-main">
        <h2>Контент</h2>
        <table class="admin-table">
            <thead>
                <tr><th>ID</th><th>Постер</th><th>Название</th><th>IMDb ID</th><th>Категория</th><th>Год</th><th>Рейтинги</th><th>Статус</th><th>Действия</th></tr>
            </thead>
            <tbody>
                <% content.forEach(item => { %>
                <tr>
                    <td><%= item.id %></td>
                    <td><img src="<%= item.poster_url || 'https://via.placeholder.com/50x75/111/fff?text=NO' %>" width="50" alt=""></td>
                    <td><%= item.title %></td>
                    <td><%= item.imdb_id || '-' %></td>
                    <td><%= item.category_name %></td>
                    <td><%= item.year %></td>
                    <td>
                        IMDb: <%= item.imdb_rating||'-' %><br>
                        KP: <%= item.kinopoisk_rating||'-' %><br>
                        RT: <%= item.rotten_tomatoes_rating||'-' %>
                    </td>
                    <td><%= item.is_active?'Активен':'Скрыт' %></td>
                    <td>
                        <a href="/admin/edit/<%= item.id %>" class="btn btn-small">Редактировать</a>
                        <a href="/admin/delete/<%= item.id %>" class="btn btn-small btn-danger" onclick="return confirm('Удалить?')">Удалить</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </main>
</body>
</html>